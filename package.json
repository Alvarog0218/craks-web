{
  "name": "craks",
  "version": "1.0.0",
  "description": "Craks Egg Distributor — Organic Precision Platform",
  "main": "server.js",
  "scripts": {
    "build:css": "tailwindcss -i ./src/styles.css -o ./public/css/styles.css --minify",
    "watch:css": "tailwindcss -i ./src/styles.css -o ./public/css/styles.css --watch",
    "start": "node server.js",
    "dev": "concurrently \"npm run watch:css\" \"nodemon server.js\""
  },
  "dependencies": {
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "geoip-lite": "^2.0.1",
    "node-ipinfo": "^4.4.0",
    "request-ip": "^3.3.0"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.7",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1"
  }
}
