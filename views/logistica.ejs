<%- include('partials/head', { title: 'Logística Global' }) %>
<body class="bg-surface font-body text-on-surface min-h-screen flex flex-col">

<%- include('partials/nav') %>

<main class="flex-1">

  <!-- ── Hero ──────────────────────────────────────────────── -->
  <section class="relative px-6 md:px-12 py-16 md:py-24 max-w-7xl mx-auto grid lg:grid-cols-2 gap-12 items-center overflow-hidden">
    <div class="relative z-10">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-secondary-container text-on-secondary-container mb-8">
        <span class="material-symbols-outlined text-sm" style="font-variation-settings:'FILL' 1">verified</span>
        <span class="text-xs font-bold uppercase tracking-widest">Global Logistics Elite</span>
      </div>
      <h1 class="font-headline text-4xl md:text-6xl font-extrabold text-on-background tracking-tighter leading-[1.05] mb-6">
        Logística de <span class="text-secondary">Precisión</span> para el Alcance Global.
      </h1>
      <p class="text-on-surface-variant text-lg max-w-xl mb-10 leading-relaxed">
        Elevamos los estándares de distribución B2B. Conectamos su producción con el mercado global mediante una cadena de frío inteligente y trazabilidad total.
      </p>
      <div class="flex flex-wrap gap-4">
        <a href="/distribuidores" class="yolk-gradient px-8 py-4 rounded-full font-headline font-black text-base text-on-primary-fixed shadow-xl shadow-primary-fixed/20 hover:-translate-y-0.5 transition-all active:scale-95">
          Unirse a la Red
        </a>
        <a href="#soluciones" class="px-8 py-4 rounded-full font-headline font-bold text-base border-2 border-outline-variant text-on-background hover:bg-surface-container-low transition-all">
          Ver Soluciones
        </a>
      </div>
    </div>
    <div class="relative">
      <div class="absolute -top-20 -right-20 w-96 h-96 bg-primary-fixed/30 blur-3xl rounded-full pointer-events-none"></div>
      <div class="relative bg-surface-container-low rounded-xl overflow-hidden p-3 shadow-2xl">
        <img
          alt="Centro logístico moderno con sistemas automatizados"
          class="w-full aspect-square object-cover rounded-lg"
          src="https://lh3.googleusercontent.com/aida-public/AB6AXuCIIXjzj-e3ZhDVn_UETbrudsuFY70ChF0YJgD5IInoajIrbnq0aTYyxJPUOPgQwnBmp36BdGKwK5Sdem33auTp2y2pO47CklZkZMqR_BfMTQG2TphPa94kUlOqoRqw9B38_5E3fEARLbE2z8WbVv99LLXIgpcJzXTrAnG8TBMkHQ4oKmTi5tq_Lztr8m3W3UBASw1Wpdflav6ZlLL8zZibCbmewf0wUkNdhnj8avFwYZ0yLfIrSSTJks1duqB8jWWuS5QuXKsXpHU"
          loading="lazy"
        />
        <div class="absolute bottom-8 left-8 p-5 bg-surface/90 backdrop-blur-md rounded-xl max-w-xs shadow-lg">
          <div class="flex items-center gap-3 mb-1">
            <span class="material-symbols-outlined text-primary-fixed-dim" style="font-variation-settings:'FILL' 1">star</span>
            <span class="font-bold text-secondary text-sm">Certificación Craks</span>
          </div>
          <p class="text-sm">99.9% de efectividad en entregas refrigeradas transcontinentales.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Global Network Stats ──────────────────────────────── -->
  <section class="py-16 bg-surface-container-low">
    <div class="px-6 md:px-12 max-w-7xl mx-auto">
      <div class="text-center max-w-3xl mx-auto mb-14">
        <h2 class="font-headline text-3xl md:text-5xl font-extrabold tracking-tight mb-4">Nuestra Red Global</h2>
        <p class="text-on-surface-variant text-lg">Más de 45 centros de distribución estratégicos conectando los continentes con precisión quirúrgica.</p>
      </div>

      <!-- Stat cards -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10">
        <div class="p-6 bg-surface rounded-xl">
          <div class="text-3xl md:text-4xl font-black text-secondary mb-1 font-headline">120+</div>
          <div class="text-xs font-bold uppercase tracking-widest text-on-surface-variant">Países Cubiertos</div>
        </div>
        <div class="p-6 bg-surface rounded-xl">
          <div class="text-3xl md:text-4xl font-black text-secondary mb-1 font-headline">1.2M</div>
          <div class="text-xs font-bold uppercase tracking-widest text-on-surface-variant">Envíos Anuales</div>
        </div>
        <div class="p-6 bg-surface rounded-xl">
          <div class="text-3xl md:text-4xl font-black text-secondary mb-1 font-headline">0.02%</div>
          <div class="text-xs font-bold uppercase tracking-widest text-on-surface-variant">Margen de Error</div>
        </div>
        <div class="p-6 bg-surface rounded-xl">
          <div class="text-3xl md:text-4xl font-black text-secondary mb-1 font-headline">24h</div>
          <div class="text-xs font-bold uppercase tracking-widest text-on-surface-variant">Soporte Crítico</div>
        </div>
      </div>

      <!-- Map -->
      <div class="rounded-xl overflow-hidden aspect-video md:aspect-[21/9] bg-surface-variant relative group">
        <img
          alt="Mapa mundial de distribución con nodos logísticos"
          class="w-full h-full object-cover"
          src="https://lh3.googleusercontent.com/aida-public/AB6AXuDEEz7aUwGikMRoNe_bM369g7E3YmegaTIB758-Dbp1MP4Kfxai5uZqkpvmNpML_N6sYY46mxbcHHAC86R5QWIloOl-lVjWjWwqLH35NU3TPHBD6kpmjWzVR34Z5qT6nsWk0mZOVG65jpGi1lCOPb2MEDHqKgMvYXvoj_HgDufE_84sXx2zMy-s3PYVTwjcz5MuQQVcNOxSpSyG6gLjlF-InsZT_51H-sxyiF_rboUkEL6GqL3oqQuTu3fiGOdBvA16zLNVyeluvXw"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-secondary/10 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity backdrop-blur-[2px]">
          <button class="bg-surface px-8 py-4 rounded-full font-bold shadow-xl flex items-center gap-2">
            <span class="material-symbols-outlined">zoom_in</span>
            Explorar Nodos Regionales
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Technology Section ────────────────────────────────── -->
  <section id="soluciones" class="py-16 md:py-24 bg-surface px-6 md:px-12">
    <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-16 items-center">
      <div class="relative order-2 lg:order-1">
        <div class="egg-curve bg-secondary-container w-full aspect-square absolute -z-10 scale-110 opacity-20"></div>
        <img
          alt="Tecnología de cadena de frío avanzada"
          class="w-full h-auto egg-curve shadow-2xl"
          src="https://lh3.googleusercontent.com/aida-public/AB6AXuAZIeF_tdz1vpIjbNc-aaaW9VaFYgH0t3cTB_frmGR5Xt3RRgvEkCk8FP_3UBSaJFXbXkiHa2JS4JwDBWeE6s65mlInSa393VqAC4TVWo_xKMkrgLtLamzIzqWUyx9xAvvUQKBsg694_rpNKiRQW7DxnbG4K-zvFK-DzdcBLRWERlTYaRkM44aAilRpFQ6TnHf01NzetLa57hq50Am-Bg373630QM56NMRozO6YNfrufeydaWGDhzsOfZbW4FstQPtXefJpC4RxDOY"
          loading="lazy"
        />
      </div>
      <div class="order-1 lg:order-2">
        <h2 class="font-headline text-3xl md:text-5xl font-extrabold tracking-tight mb-10">Tecnología de Vanguardia e Integridad Orgánica</h2>
        <div class="space-y-8">
          <div class="flex gap-5">
            <div class="flex-shrink-0 w-14 h-14 rounded-full bg-primary-fixed flex items-center justify-center">
              <span class="material-symbols-outlined text-on-primary-fixed text-2xl">ac_unit</span>
            </div>
            <div>
              <h4 class="text-lg font-bold mb-1">Control Térmico Activo</h4>
              <p class="text-on-surface-variant leading-relaxed">Sensores de grado médico que mantienen la temperatura exacta desde el origen hasta el destino final, sin oscilaciones.</p>
            </div>
          </div>
          <div class="flex gap-5">
            <div class="flex-shrink-0 w-14 h-14 rounded-full bg-primary-fixed flex items-center justify-center">
              <span class="material-symbols-outlined text-on-primary-fixed text-2xl">token</span>
            </div>
            <div>
              <h4 class="text-lg font-bold mb-1">Blockchain Traceability</h4>
              <p class="text-on-surface-variant leading-relaxed">Cada lote es registrado en un libro mayor inmutable. Transparencia total para socios y consumidores finales.</p>
            </div>
          </div>
          <div class="flex gap-5">
            <div class="flex-shrink-0 w-14 h-14 rounded-full bg-primary-fixed flex items-center justify-center">
              <span class="material-symbols-outlined text-on-primary-fixed text-2xl">eco</span>
            </div>
            <div>
              <h4 class="text-lg font-bold mb-1">Rutas Optimizadas (IA)</h4>
              <p class="text-on-surface-variant leading-relaxed">Algoritmos de aprendizaje profundo reducen la huella de carbono minimizando tiempos de espera y recorridos.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Partner Benefits ──────────────────────────────────── -->
  <section class="py-16 bg-surface-container-low px-6 md:px-12">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-6">
        <div class="max-w-2xl">
          <h2 class="font-headline text-3xl md:text-5xl font-extrabold tracking-tight mb-3">Ventajas de ser Partner</h2>
          <p class="text-on-surface-variant text-lg">No somos solo transportistas; somos el motor de crecimiento de su negocio.</p>
        </div>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-surface p-8 md:p-10 rounded-xl group hover:bg-secondary transition-all duration-500 ghost-border">
          <span class="material-symbols-outlined text-5xl text-secondary group-hover:text-primary-fixed transition-colors mb-6 block" style="font-variation-settings:'FILL' 1">inventory_2</span>
          <h3 class="text-xl font-bold mb-3 group-hover:text-white transition-colors">Stock Garantizado</h3>
          <p class="text-on-surface-variant group-hover:text-white/80 leading-relaxed text-sm">Prioridad absoluta en el reabastecimiento de inventario crítico con cláusulas de cumplimiento por contrato.</p>
        </div>
        <div class="bg-surface p-8 md:p-10 rounded-xl group hover:bg-secondary transition-all duration-500 ghost-border">
          <span class="material-symbols-outlined text-5xl text-secondary group-hover:text-primary-fixed transition-colors mb-6 block" style="font-variation-settings:'FILL' 1">support_agent</span>
          <h3 class="text-xl font-bold mb-3 group-hover:text-white transition-colors">Soporte Elite 24/7</h3>
          <p class="text-on-surface-variant group-hover:text-white/80 leading-relaxed text-sm">Un gestor de cuenta dedicado y línea directa con nuestro centro de operaciones logísticas internacionales.</p>
        </div>
        <div class="bg-surface p-8 md:p-10 rounded-xl group hover:bg-secondary transition-all duration-500 ghost-border">
          <span class="material-symbols-outlined text-5xl text-secondary group-hover:text-primary-fixed transition-colors mb-6 block" style="font-variation-settings:'FILL' 1">verified_user</span>
          <h3 class="text-xl font-bold mb-3 group-hover:text-white transition-colors">Calidad Certificada</h3>
          <p class="text-on-surface-variant group-hover:text-white/80 leading-relaxed text-sm">Acceso a nuestras certificaciones internacionales (ISO, Organic Precision) para fortalecer su propuesta de valor.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Testimonial + Form CTA ────────────────────────────── -->
  <section class="py-16 px-6 md:px-12 relative overflow-hidden">
    <div class="absolute top-0 right-0 w-1/3 h-full bg-secondary-container/20 translate-x-1/2 rounded-full blur-[100px] pointer-events-none"></div>
    <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-16 items-start">
      <div>
        <h2 class="font-headline text-3xl md:text-5xl font-extrabold tracking-tighter mb-6">Inicie su solicitud de asociación</h2>
        <p class="text-on-surface-variant text-lg mb-10 leading-relaxed">Estamos buscando socios que compartan nuestra obsesión por la calidad y la eficiencia. Complete el formulario y nuestro equipo le contactará en menos de 48 horas.</p>
        <div class="p-7 bg-surface-container rounded-xl border-l-4 border-secondary">
          <p class="italic text-on-surface font-medium leading-relaxed">"Craks Logistics transformó nuestra capacidad de entrega en mercados asiáticos, reduciendo las mermas en un 40% desde el primer mes."</p>
          <div class="mt-5 flex items-center gap-4">
            <div class="w-11 h-11 rounded-full bg-surface-container-highest"></div>
            <div>
              <div class="font-bold text-sm">Marco Valenzuela</div>
              <div class="text-xs text-on-surface-variant">Director de Operaciones, Global Food Group</div>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-surface-container-low p-8 md:p-10 rounded-xl shadow-xl shadow-on-surface/5">
        <form class="space-y-5">
          <div class="grid sm:grid-cols-2 gap-5">
            <div class="space-y-1.5">
              <label class="text-xs font-bold uppercase text-on-surface-variant tracking-widest ml-4">Empresa</label>
              <input type="text" placeholder="Nombre de la empresa" class="w-full bg-surface-container-high rounded-full px-6 py-4 text-on-surface focus:ring-2 focus:ring-secondary/30 focus:bg-surface-bright outline-none transition-all" />
            </div>
            <div class="space-y-1.5">
              <label class="text-xs font-bold uppercase text-on-surface-variant tracking-widest ml-4">País</label>
              <input type="text" placeholder="País de operaciones" class="w-full bg-surface-container-high rounded-full px-6 py-4 text-on-surface focus:ring-2 focus:ring-secondary/30 focus:bg-surface-bright outline-none transition-all" />
            </div>
          </div>
          <div class="space-y-1.5">
            <label class="text-xs font-bold uppercase text-on-surface-variant tracking-widest ml-4">Correo Corporativo</label>
            <input type="email" placeholder="email@empresa.com" class="w-full bg-surface-container-high rounded-full px-6 py-4 text-on-surface focus:ring-2 focus:ring-secondary/30 focus:bg-surface-bright outline-none transition-all" />
          </div>
          <div class="space-y-1.5">
            <label class="text-xs font-bold uppercase text-on-surface-variant tracking-widest ml-4">Volumen Estimado Mensual</label>
            <select class="w-full bg-surface-container-high rounded-full px-6 py-4 text-on-surface focus:ring-2 focus:ring-secondary/30 outline-none transition-all appearance-none">
              <option>Menos de 10,000 unidades</option>
              <option>10,000 – 100,000 unidades</option>
              <option>100,000 – 1M unidades</option>
              <option>Más de 1M unidades</option>
            </select>
          </div>
          <div class="space-y-1.5">
            <label class="text-xs font-bold uppercase text-on-surface-variant tracking-widest ml-4">Mensaje</label>
            <textarea rows="3" placeholder="Cuéntenos sobre su operación logística actual..." class="w-full bg-surface-container-high rounded-xl px-6 py-4 text-on-surface focus:ring-2 focus:ring-secondary/30 focus:bg-surface-bright outline-none transition-all resize-none"></textarea>
          </div>
          <button type="submit" class="w-full yolk-gradient text-on-primary-fixed py-5 rounded-full font-bold text-lg shadow-xl active:scale-[0.99] transition-all hover:brightness-105">
            Enviar Solicitud
          </button>
        </form>
      </div>
    </div>
  </section>

</main>

<%- include('partials/footer') %>

</body>
</html>
