<!-- ── Navigation ────────────────────────────────────────── -->
<div x-data="{ open: false }">

  <!-- Mobile Drawer Backdrop -->
  <div
    x-show="open"
    x-transition.opacity
    @click="open = false"
    class="fixed inset-0 bg-black/30 z-40 md:hidden"
    style="display:none"
  ></div>

  <!-- Mobile Drawer -->
  <aside
    x-show="open"
    x-transition:enter="transition ease-out duration-300"
    x-transition:enter-start="-translate-x-full"
    x-transition:enter-end="translate-x-0"
    x-transition:leave="transition ease-in duration-200"
    x-transition:leave-start="translate-x-0"
    x-transition:leave-end="-translate-x-full"
    class="fixed inset-y-0 left-0 w-80 z-50 flex flex-col p-6 bg-surface rounded-r-xl shadow-2xl shadow-on-surface/10 md:hidden"
    style="display:none"
  >
    <div class="flex items-center justify-between mb-10 px-2">
      <img src="/public/assets/logo_azul.png" alt="Craks" class="h-8 w-auto" />
      <button @click="open = false" class="p-2 text-on-surface-variant hover:text-on-surface transition-colors">
        <span class="material-symbols-outlined">close</span>
      </button>
    </div>
    <nav class="flex flex-col gap-1">
      <a href="/"             class="<%= page==='inicio'          ? 'bg-primary-fixed text-on-primary-fixed' : 'text-on-surface hover:bg-surface-container-low' %> rounded-full font-bold px-6 py-3 flex items-center gap-4 transition-colors">
        <span class="material-symbols-outlined">home</span> <%= t.nav_home %>
      </a>
      <a href="/productos"    class="<%= page==='productos'        ? 'bg-primary-fixed text-on-primary-fixed' : 'text-on-surface hover:bg-surface-container-low' %> rounded-full font-bold px-6 py-3 flex items-center gap-4 transition-colors">
        <span class="material-symbols-outlined">egg</span> <%= t.nav_products %>
      </a>
      <a href="/nosotros"     class="<%= page==='nosotros'         ? 'bg-primary-fixed text-on-primary-fixed' : 'text-on-surface hover:bg-surface-container-low' %> rounded-full font-bold px-6 py-3 flex items-center gap-4 transition-colors">
        <span class="material-symbols-outlined">group</span> <%= t.nav_about %>
      </a>
      <a href="/distribuidores" class="<%= page==='distribuidores' ? 'bg-primary-fixed text-on-primary-fixed' : 'text-on-surface hover:bg-surface-container-low' %> rounded-full font-bold px-6 py-3 flex items-center gap-4 transition-colors">
        <span class="material-symbols-outlined">hub</span> <%= t.nav_distributors %>
      </a>
      <a href="/logistica"    class="<%= page==='logistica'        ? 'bg-primary-fixed text-on-primary-fixed' : 'text-on-surface hover:bg-surface-container-low' %> rounded-full font-bold px-6 py-3 flex items-center gap-4 transition-colors">
        <span class="material-symbols-outlined">local_shipping</span> <%= t.nav_logistics %>
      </a>
    </nav>

    <!-- Mobile Lang Toggle -->
    <div class="mt-6 flex items-center gap-1 bg-surface-container-high rounded-full p-1 self-start">
      <a href="/lang/es" class="<%= lang==='es' ? 'bg-primary text-on-primary' : 'text-on-surface-variant hover:text-on-surface' %> px-4 py-1.5 rounded-full text-xs font-bold transition-colors">ES</a>
      <a href="/lang/en" class="<%= lang==='en' ? 'bg-primary text-on-primary' : 'text-on-surface-variant hover:text-on-surface' %> px-4 py-1.5 rounded-full text-xs font-bold transition-colors">EN</a>
    </div>

    <div class="mt-auto pt-8">
      <a href="/distribuidores" class="yolk-gradient block w-full text-center py-4 rounded-full font-bold text-on-primary-fixed text-sm uppercase tracking-wide">
        <%= t.nav_partner %>
      </a>
    </div>
  </aside>

  <!-- Top Nav Bar -->
  <header class="bg-surface/80 glass-nav sticky top-0 z-30 w-full">
    <div class="flex items-center justify-between max-w-7xl mx-auto px-6 py-4">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2">
        <img src="/public/assets/logo_azul.png" alt="Craks" class="h-10 w-auto" />
      </a>

      <!-- Desktop Links -->
      <nav class="hidden md:flex items-center gap-8">
        <a href="/"               class="font-headline text-sm font-bold uppercase tracking-wider transition-colors duration-200 <%=page==='inicio'          ? 'text-petrol border-b-2 border-primary-fixed pb-0.5' : 'text-on-surface-variant hover:text-petrol'%>"><%= t.nav_home %></a>
        <a href="/productos"      class="font-headline text-sm font-bold uppercase tracking-wider transition-colors duration-200 <%=page==='productos'        ? 'text-petrol border-b-2 border-primary-fixed pb-0.5' : 'text-on-surface-variant hover:text-petrol'%>"><%= t.nav_products %></a>
        <a href="/nosotros"       class="font-headline text-sm font-bold uppercase tracking-wider transition-colors duration-200 <%=page==='nosotros'         ? 'text-petrol border-b-2 border-primary-fixed pb-0.5' : 'text-on-surface-variant hover:text-petrol'%>"><%= t.nav_about %></a>
        <a href="/distribuidores" class="font-headline text-sm font-bold uppercase tracking-wider transition-colors duration-200 <%=page==='distribuidores' ? 'text-petrol border-b-2 border-primary-fixed pb-0.5' : 'text-on-surface-variant hover:text-petrol'%>"><%= t.nav_distributors %></a>
        <a href="/logistica"      class="font-headline text-sm font-bold uppercase tracking-wider transition-colors duration-200 <%=page==='logistica'        ? 'text-petrol border-b-2 border-primary-fixed pb-0.5' : 'text-on-surface-variant hover:text-petrol'%>"><%= t.nav_logistics %></a>
      </nav>

      <!-- Right actions -->
      <div class="flex items-center gap-3">
        <!-- Language Toggle -->
        <div class="flex items-center gap-0.5 bg-surface-container-high border border-outline-variant/30 rounded-full p-0.5">
          <a href="/lang/es" class="<%= lang==='es' ? 'bg-primary text-on-primary' : 'text-on-surface-variant hover:text-on-surface' %> px-2 py-1 rounded-full text-[10px] font-bold transition-colors">ES</a>
          <a href="/lang/en" class="<%= lang==='en' ? 'bg-primary text-on-primary' : 'text-on-surface-variant hover:text-on-surface' %> px-2 py-1 rounded-full text-[10px] font-bold transition-colors">EN</a>
        </div>
        <a href="/distribuidores" class="hidden sm:block yolk-gradient text-on-primary-fixed px-6 py-2.5 rounded-full font-bold text-sm uppercase tracking-wide transition-all active:scale-95">
          <%= t.nav_orders %>
        </a>
        <!-- Mobile burger -->
        <button @click="open = true" class="md:hidden p-2 text-petrol" aria-label="Abrir menú">
          <span class="material-symbols-outlined text-3xl">menu</span>
        </button>
      </div>

    </div>
  </header>

</div>
