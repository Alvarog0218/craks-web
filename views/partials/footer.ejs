<!-- ── Footer ─────────────────────────────────────────────── -->
<footer class="bg-surface-container-low rounded-t-xl mt-auto w-full">
  <div class="max-w-7xl mx-auto px-8 py-16 grid grid-cols-1 md:grid-cols-4 gap-10">

    <!-- Brand -->
    <div class="md:col-span-1 flex flex-col gap-4">
      <div class="flex items-center gap-2">
        <img src="/public/assets/logo_azul.png" alt="Craks" class="h-7 w-auto" />
      </div>
      <p class="text-on-surface-variant text-sm leading-relaxed">
        <%= t.footer_tagline %>
      </p>
      <div class="flex gap-3 mt-2">
        <a href="#" class="w-9 h-9 rounded-full bg-surface-container-highest flex items-center justify-center text-on-surface-variant hover:text-petrol transition-colors">
          <span class="material-symbols-outlined text-lg">public</span>
        </a>
        <a href="#" class="w-9 h-9 rounded-full bg-surface-container-highest flex items-center justify-center text-on-surface-variant hover:text-petrol transition-colors">
          <span class="material-symbols-outlined text-lg">mail</span>
        </a>
        <a href="#" class="w-9 h-9 rounded-full bg-surface-container-highest flex items-center justify-center text-on-surface-variant hover:text-petrol transition-colors">
          <span class="material-symbols-outlined text-lg">share</span>
        </a>
      </div>
    </div>

    <!-- Resources -->
    <div>
      <h5 class="font-headline font-bold text-petrol text-xs uppercase tracking-widest mb-6"><%= t.footer_resources %></h5>
      <ul class="space-y-3">
        <li><a href="/distribuidores" class="text-on-surface-variant text-sm hover:text-petrol transition-colors"><%= t.footer_supply %></a></li>
        <li><a href="/logistica" class="text-on-surface-variant text-sm hover:text-petrol transition-colors"><%= t.footer_global %></a></li>
        <li><a href="/nosotros" class="text-on-surface-variant text-sm hover:text-petrol transition-colors"><%= t.footer_sustain %></a></li>
      </ul>
    </div>

    <!-- Company -->
    <div>
      <h5 class="font-headline font-bold text-petrol text-xs uppercase tracking-widest mb-6"><%= t.footer_company %></h5>
      <ul class="space-y-3">
        <li><a href="/nosotros" class="text-on-surface-variant text-sm hover:text-petrol transition-colors"><%= t.footer_about %></a></li>
        <li><a href="#" class="text-on-surface-variant text-sm hover:text-petrol transition-colors"><%= t.footer_press %></a></li>
        <li><a href="#" class="text-on-surface-variant text-sm hover:text-petrol transition-colors"><%= t.footer_privacy %></a></li>
      </ul>
    </div>

    <!-- Certification -->
    <div>
      <h5 class="font-headline font-bold text-petrol text-xs uppercase tracking-widest mb-6"><%= t.footer_cert %></h5>
      <div class="bg-surface-container-highest p-5 rounded-xl">
        <p class="text-xs text-on-surface-variant leading-relaxed italic">
          "<%= t.footer_cert_quote %>"
        </p>
      </div>
      <div class="flex gap-2 mt-4">
        <div class="w-9 h-9 bg-surface-container-highest rounded-full flex items-center justify-center">
          <span class="material-symbols-outlined text-petrol text-sm">verified</span>
        </div>
        <div class="w-9 h-9 bg-surface-container-highest rounded-full flex items-center justify-center">
          <span class="material-symbols-outlined text-petrol text-sm">workspace_premium</span>
        </div>
      </div>
    </div>

  </div>

  <!-- Bottom bar -->
  <div class="border-t border-outline-variant/20 max-w-7xl mx-auto px-8 py-6 flex flex-col sm:flex-row justify-between items-center gap-4">
    <p class="text-xs text-on-surface-variant">© 2026 Craks Egg Distribution Ltd. International Standards Certified.</p>
    <div class="flex gap-6 text-xs font-bold uppercase text-on-surface-variant">
      <a href="#" class="hover:text-petrol transition-colors">Instagram</a>
      <a href="#" class="hover:text-petrol transition-colors">LinkedIn</a>
      <a href="#" class="hover:text-petrol transition-colors">Twitter</a>
    </div>
  </div>
</footer>
